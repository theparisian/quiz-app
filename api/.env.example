# Database
DATABASE_URL="mysql://root:password@localhost:3306/quiz_app_dev"
# Vitest remplace automatiquement `quiz_app_dev` par `quiz_app_test` dans DATABASE_URL sauf si :
# DATABASE_URL_TEST="mysql://root:password@localhost:3306/quiz_app_test"

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# JWT
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# SMTP OVH (cohérent avec UNION)
SMTP_HOST="ssl0.ovh.net"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="Quiz App"

# OAuth (joueurs uniquement — scaffolding PR2, activation PR5)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
APPLE_OAUTH_CLIENT_ID=""
APPLE_OAUTH_TEAM_ID=""
APPLE_OAUTH_KEY_ID=""
APPLE_OAUTH_PRIVATE_KEY=""

# Base URLs (pour les liens dans les emails)
APP_URL_ADMIN="http://localhost:3004"
APP_URL_CONSOLE="http://localhost:3003"
APP_URL_MOBILE="http://localhost:3002"

# Seed
SEED_SUPER_ADMIN_EMAIL="anzio@example.com"

# Storage (fichiers media locaux ou stub S3)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_URL=http://localhost:3000/uploads
UPLOAD_MAX_SIZE_MB=2

# IA (Anthropic) — CI: AI_PROVIDER=mock
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_RATE_LIMIT_PER_HOUR=5

# Lots / QR redeem (PR7)
PRIZE_HMAC_SECRET=
PRIZE_REDEEM_BASE_URL=https://demo.uxii.fr/redeem
PRIZE_UNSUBSCRIBE_BASE_URL=https://demo.uxii.fr/unsubscribe

# S3 (placeholder — stub tant que provider non implémenté)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_PUBLIC_URL=
