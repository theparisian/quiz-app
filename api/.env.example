# Database
DATABASE_URL="mysql://root:password@localhost:3306/quiz_app_dev"

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# JWT
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# SMTP OVH (cohérent avec UNION)
SMTP_HOST="ssl0.ovh.net"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="Quiz App"

# OAuth (joueurs uniquement — scaffolding PR2, activation PR5)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
APPLE_OAUTH_CLIENT_ID=""
APPLE_OAUTH_TEAM_ID=""
APPLE_OAUTH_KEY_ID=""
APPLE_OAUTH_PRIVATE_KEY=""

# Base URLs (pour les liens dans les emails)
APP_URL_ADMIN="http://localhost:3004"
APP_URL_CONSOLE="http://localhost:3003"
APP_URL_MOBILE="http://localhost:3002"

# Seed
SEED_SUPER_ADMIN_EMAIL="anzio@example.com"
