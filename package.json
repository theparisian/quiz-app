{
  "name": "quiz-app",
  "version": "2.0.0",
  "private": true,
  "description": "shh — Plateforme multi-cinéma de quizz interactifs",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo test",
    "test:ai-live": "pnpm --filter @quiz-app/api test:ai-live",
    "sim:session": "pnpm --filter @quiz-app/api sim:session",
    "db:seed": "pnpm --filter @quiz-app/api db:seed",
    "dev:full-stack": "turbo dev --filter=@quiz-app/api --filter=@quiz-app/admin --filter=@quiz-app/console --filter=@quiz-app/player --filter=@quiz-app/mobile",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
